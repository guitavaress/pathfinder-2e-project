# Copie para .env e ajuste se necessário. O .env é ignorado pelo git.
# Host do Ollama (padrão: instalação local)
OLLAMA_HOST=http://localhost:11434

# Dois modelos (precisam estar baixados: `ollama pull <modelo>`):
# - RULES_MODEL: resolve as regras/ferramentas (tool calling).
# - NARRATIVE_MODEL: escreve a narrativa.
# Padrão = par grande (máxima qualidade), mas NÃO cabe concorrente em 12GB VRAM +
# ~15GB RAM → turnos lentos (offload/troca). Para fluidez, troque pelo par menor:
#   RULES_MODEL=qwen3:8b
#   NARRATIVE_MODEL=gemma3:12b
RULES_MODEL=qwen3:30b-a3b
NARRATIVE_MODEL=gemma3:27b

# Tente manter ambos carregados (efeito limitado se faltar memória):
# OLLAMA_MAX_LOADED_MODELS=2

# Porta do backend do GM (opcional, padrão 3001)
PORT=3001
