# Copy to .env and adjust if needed. .env is gitignored.
# LM Studio's OpenAI-compatible base URL (default: local install on port 1234).
# Start the server with: lms server start
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Two models (must be downloaded in LM Studio: `lms get <model>`):
# - RULES_MODEL: resolves the rules/tools (tool calling).
# - NARRATIVE_MODEL: writes the narrative.
# Use the model KEY exactly as LM Studio reports it (see `lms ls` or
# GET /v1/models). Default = large pair (max quality), but the two ~17-18 GB
# models do NOT fit together in 12 GB VRAM, so LM Studio swaps models each turn
# (slower). For fluidity, download and point these at a smaller pair instead.
RULES_MODEL=qwen/qwen3-30b-a3b
NARRATIVE_MODEL=google/gemma-3-27b

# GM backend port (optional, default 3001)
PORT=3001
