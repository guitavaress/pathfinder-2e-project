# Copy to .env and adjust if needed. .env is gitignored.
# LM Studio's OpenAI-compatible base URL (default: local install on port 1234).
# Start the server with: lms server start
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# GM model. By default ONE model drives both stages (rules + narrative), each
# with its own context (system prompt + thread). This keeps a single model
# resident in VRAM — no per-turn weight swap. Use the model KEY exactly as
# LM Studio reports it (see `lms ls` or GET /v1/models); it must be downloaded
# (`lms get <model>`). Qwen3 is a good single pick (strong tool-calling + prose).
GM_MODEL=qwen/qwen3-30b-a3b

# Optional: split the two stages across two models (specialization at the cost
# of VRAM). If BOTH are set to different models and don't fit together, LM Studio
# swaps weights each turn (minutes/turn on ~12 GB). Unset = both use GM_MODEL.
# RULES_MODEL=qwen/qwen3-30b-a3b
# NARRATIVE_MODEL=google/gemma-3-27b

# GM backend port (optional, default 3001)
PORT=3001
